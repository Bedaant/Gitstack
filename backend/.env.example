# ── MongoDB ──────────────────────────────────────────────────────
# Get a free M0 cluster at https://cloud.mongodb.com
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/gitstack?retryWrites=true&w=majority
DB_NAME=gitstack

# ── Google Gemini ─────────────────────────────────────────────────
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GitHub ────────────────────────────────────────────────────────
# Optional but strongly recommended — raises rate limit from 60 → 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Clerk Auth ────────────────────────────────────────────────────
# Sign up at https://clerk.com → create an app → API Keys
# JWKS URL format: https://<your-clerk-instance>.clerk.accounts.dev/.well-known/jwks.json
# Find it in Clerk Dashboard → API Keys → Show JWKS URL
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# ── CORS ──────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: your Vercel frontend URL, e.g. https://gitstack.vercel.app
# Multiple origins: comma-separated, e.g. https://gitstack.vercel.app,https://www.gitstack.pro
CORS_ORIGINS=http://localhost:3000

# ── Push notifications (optional) ────────────────────────────────
# Free phone alerts via https://ntfy.sh — pick any unique topic name
NTFY_TOPIC=gitstack-alerts

# ── Razorpay (Marketplace payments) ──────────────────────────────
# Sign up at https://razorpay.com → Dashboard → Settings → API Keys
# Test mode keys start with rzp_test_
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here
# Webhook secret — set this when creating a webhook in Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
# Platform fee percentage taken from each sale (default 15)
PLATFORM_FEE_PERCENT=15

# ── Cloudflare R2 (Marketplace file storage) ─────────────────────
# Create a bucket at https://dash.cloudflare.com → R2 → Create bucket
# Recommended bucket name: gitstack-marketplace
# Generate API tokens at R2 → Manage R2 API Tokens (Object Read & Write scope)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=gitstack-marketplace
# Public URL for screenshots — enable public access on the bucket and copy the public dev URL
# Format: https://pub-xxxxxxxx.r2.dev (or a custom domain you've connected)
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── Redis (fastapi-cache) ────────────────────────────────────────
# Required for endpoint caching — use Upstash, Redis Cloud, or local Redis
# For local dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Email (fastapi-mail) ───────────────────────────────────────────
# Provider: Resend (https://resend.com) — Recommended for GitStack
# Free tier: 3,000 emails/day
# SMTP docs: https://resend.com/docs/send-with-smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your_resend_api_key_here
SMTP_TLS=true

# Default / marketing sender
SMTP_FROM_EMAIL=hello@gitstack.pro
SMTP_FROM_NAME=GitStack

# Content digest sender (Daily Drop, Weekly Stack)
SMTP_DROP_EMAIL=drop@gitstack.pro
SMTP_DROP_NAME="GitStack Daily Drop"

# Marketplace sender (purchases, payouts, setup requests)
SMTP_MARKETPLACE_EMAIL=marketplace@gitstack.pro
SMTP_MARKETPLACE_NAME="GitStack Marketplace"

# Support reply-to address (shown on all emails)
SMTP_HELP_EMAIL=help@gitstack.pro

# System / automated sender
SMTP_NOREPLY_EMAIL=noreply@gitstack.pro

# ── Email Token Secret (for unsubscribe/preferences magic links) ──
# Generate a random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
EMAIL_TOKEN_SECRET=change_this_to_a_random_string_32_chars_min

# ── Frontend URL (for Razorpay redirect URLs) ────────────────────
FRONTEND_URL=http://localhost:3000
