# ── Backend URL ───────────────────────────────────────────────────
# Local dev:   http://localhost:8001
# Production:  your Render backend URL, e.g. https://gitstack-backend.onrender.com
# Set this in your Vercel project → Settings → Environment Variables
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ── Site URL (used for SEO canonical tags, OG images, sitemaps) ──
# Must match your deployed domain exactly (no trailing slash)
REACT_APP_SITE_URL=https://gitstack.pro
